{
  "IsEncrypted": false,

  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated"
  },

  "KeyVaultConfig": {
    "Url": "https://kv-webscrapper.vault.azure.net/"
  },

  "DbSettings": {
    "MongoUrl": "<value-in-azure-key-vault>",
    "DatabaseName": "<value-in-azure-key-vault>"
  },

  "SmtpSettings": {
    "SenderEmail": "<value-in-azure-key-vault>",
    "SenderPassword": "<value-in-azure-key-vault>",
    "SmtpHost": "<value-in-azure-key-vault>",
    "SmtpPort": "<value-in-azure-key-vault>",
    "SecureSocketOptions": "<value-in-azure-key-vault>"
  }
}
